# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Webhook Server
WEBHOOK_PORT=3402
WEBHOOK_SECRET=your_webhook_secret_here

# MoltsPay
MOLTSPAY_API_URL=https://moltspay.com

# Coinbase Onramp (for card payments)
# Get from: https://portal.cdp.coinbase.com → Create Project → Enable Onramp
COINBASE_ONRAMP_APP_ID=your_app_id_here

# Database
DATABASE_PATH=./data/bot.db

# Default Chain
DEFAULT_CHAIN=base
